# ──────────────────────────────────────────────────────────────────
# 기본값: /api (설정 없이도 로컬/Vercel 모두 Next.js API Routes 사용)
# ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=/api   ← 기본값이므로 생략 가능

# ──────────────────────────────────────────────────────────────────
# 실제 백엔드 서버 연결 시에만 아래 값 설정
# ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=https://api.everp.co.kr/api

# ──────────────────────────────────────────────────────────────────
# 로컬 개발 시 MSW 사용 (브라우저 Service Worker 방식)
# ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_MOCKING=enabled
