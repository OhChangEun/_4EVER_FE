# ──────────────────────────────────────────────────────────────────
# 실제 API 서버 연결 (기본값, 따로 설정하지 않아도 됩니다)
# ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=https://api.everp.co.kr/api

# ──────────────────────────────────────────────────────────────────
# Vercel 배포 시 Next.js API Routes(Mock) 사용
# Vercel > Settings > Environment Variables 에 아래 값을 추가하세요
# ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=/api

# ──────────────────────────────────────────────────────────────────
# 로컬 개발 시 MSW 사용 (브라우저 Service Worker 방식)
# ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_MOCKING=enabled
